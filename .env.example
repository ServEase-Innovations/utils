# HTTP ports (defaults avoid clashes with other Serveaso services in the monorepo)
PORT=3030
UTILS_EMAIL_PORT=4030

# Razorpay (required for POST /create-order)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Monorepo service base URLs (used by GET /api/platform-status for HTTP health probes)
PAYMENTS_SERVICE_URL=http://127.0.0.1:4100
PROVIDERS_SERVICE_URL=http://127.0.0.1:4000
PREFERENCES_SERVICE_URL=http://127.0.0.1:3001
COUPONS_SERVICE_URL=http://127.0.0.1:3002
REVIEWS_SERVICE_URL=http://127.0.0.1:5005
CHAT_SERVICE_URL=http://127.0.0.1:5000
# optional — omit to show as “N/A” in status
# NOTIFICATIONS_SERVICE_URL=http://127.0.0.1:45XX

# MongoDB — required for FCM device token storage (Mongoose `DeviceToken` → collection `devicetokens`)
# Use the same cluster your utils service connects to in your environment.
MONGO_URI=mongodb://localhost:27017/serveaso

# Firebase Cloud Messaging (utils POST /api/push/send)
# Easiest local setup: download service account JSON from Firebase Console and save as:
#   services/utils/firebase-service-account.json   (gitignored; auto-loaded in dev)
# Or point to your file:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# Or paste minified JSON / base64 (for Render/host env):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Shared secret for admin web (header X-Admin-Push-Secret) — must match REACT_APP_ADMIN_PUSH_SECRET
ADMIN_PUSH_SECRET=serveaso-test-push-secret

# Copy from your existing .env.development / Auth0 / Postgres as needed.
